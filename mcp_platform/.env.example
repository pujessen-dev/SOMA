APP_NAME=your-platform-api
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Postgres
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/appdb
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false
RDS_SECRET_ID=
RDS_WRITER_HOST=
RDS_READER_HOST=
RDS_PORT=5432
RDS_DB_NAME=
RDS_USE_READER=false

# S3
S3_BUCKET=s114-miners-solutions

# Bittensor / Metagraph
BT_NETUID=114
BT_NETWORK=
BT_CHAIN_ENDPOINT=
BT_METAGRAPH_EPOCH_LENGTH=100
BT_METAGRAPH_SYNC_SECS=60

# Weight Setting
MAX_MINERS_FOR_WEIGHTS=1

# QA Generator
QA_GENERATOR_MODEL=
OPENROUTER_API_KEY=

# Remote Sandbox Service Configuration (Required)
# URL of the remote sandbox service running on separate machine
SANDBOX_SERVICE_URL=http://sandbox-host:8001
# HTTP timeout for sandbox service requests (seconds)
SANDBOX_SERVICE_TIMEOUT=120.0
# Sandbox execution timeout (seconds)
SANDBOX_EXEC_TIMEOUT_SECONDS=60.0
# Sandbox container TTL (seconds)
SANDBOX_CONTAINER_TTL_SECONDS=120.0
