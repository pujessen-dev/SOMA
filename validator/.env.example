## Validator core
# Wallet name (bittensor wallet)
WALLET_NAME=
# Wallet hotkey (bittensor hotkey name)
WALLET_HOTKEY=
# Bittensor netuid (default: 114)
NETUID=114

# Subtensor network (finney, test, local)
SUBTENSOR_NETWORK=finney
# Subtensor chain endpoint (optional, overrides SUBTENSOR_NETWORK if set)
SUBTENSOR_ENDPOINT=

# Platform API base URL
PLATFORM_URL=http://platform:8000
# Platform signer SS58 (used to verify responses)
PLATFORM_SIGNER_SS58=

# Validator bind host and port
VALIDATOR_HOST=0.0.0.0
VALIDATOR_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Poll interval for fetching tasks (seconds)
TASK_POLL_INTERVAL_SECONDS=15
# Maximum backoff interval when no tasks available (seconds)
MAX_BACKOFF_INTERVAL_SECONDS=300
# Backoff multiplier for exponential backoff
BACKOFF_MULTIPLIER=2.0

# Disable run loop on startup (1 = disabled)
VALIDATOR_DISABLE_RUN=0
# Disable app initialization (1 = app is not created)
VALIDATOR_DISABLE_APP_INIT=0

# Max concurrent evaluations (default: CPU count - 1, max 8)
MAX_CONCURRENT_EVALUATIONS=

## LLM Scoring (OpenRouter AI) 
#TODO integrate Chutes
# OpenRouter API URL
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# OpenRouter API token (required for LLM scoring)
OPENROUTER_API_TOKEN=
# OpenRouter model to use
OPENROUTER_MODEL=openai/gpt-4o-mini
# LLM request timeout (seconds)
LLM_TIMEOUT_SECONDS=30
# LLM max tokens per request
LLM_MAX_TOKENS=1024
# LLM temperature
LLM_TEMPERATURE=0.2

## Sandbox image runtime (used inside container)
# Path to submitted code file
INPUT_PATH=/sandbox/input/code.py
# Path to task payload
TASK_PATH=/sandbox/input/task.json
# Path for output payload
OUTPUT_PATH=/sandbox/output/output.json
