## Validator core
# Wallet name (bittensor wallet)
WALLET_NAME=
# Wallet hotkey (bittensor hotkey name)
WALLET_HOTKEY=
# Bittensor netuid (default: 114)
NETUID=114

# Bittensor network (finney, test, local)
BT_NETWORK=finney

# Platform API base URL
PLATFORM_URL=https://platform.thesoma.ai
# Platform signer SS58 (used to verify responses)
PLATFORM_SIGNER_SS58=5H1nRfbCbDGh3t17er9Y8hwFEsXCrjBbaN6jLrnez8KpUKju

# Validator bind host and port
# Provide a public IP address, so it can be accessed by the platform.
VALIDATOR_HOST=
VALIDATOR_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Poll interval for fetching tasks (seconds)
TASK_POLL_INTERVAL_SECONDS=15
# Maximum backoff interval when no tasks available (seconds)
MAX_BACKOFF_INTERVAL_SECONDS=300
# Backoff multiplier for exponential backoff
BACKOFF_MULTIPLIER=2.0

# Max concurrent evaluations (default: CPU count - 1, max 8)
MAX_CONCURRENT_EVALUATIONS=4

## LLM Scoring (OpenRouter AI) 
#TODO integrate Chutes
# OpenRouter API URL
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# OpenRouter API token (required for LLM scoring)
OPENROUTER_API_TOKEN=
# OpenRouter model to use
OPENROUTER_MODEL=moonshotai/kimi-k2-0905
# LLM request timeout (seconds)
LLM_TIMEOUT_SECONDS=120
# LLM max tokens per request
LLM_MAX_TOKENS=1024
# LLM temperature
LLM_TEMPERATURE=0.0


