## ============================================================
## MCP Subnet Validator Configuration
## ============================================================
## Copy this file to .env in the validator/ directory
## and fill in your specific values

## ============================================================
## BITTENSOR WALLET SETTINGS
## ============================================================

# Your Bittensor wallet name (created with btcli wallet new_coldkey)
WALLET_NAME=default

# Your Bittensor hotkey name (created with btcli wallet new_hotkey)
WALLET_HOTKEY=default

# Subnet UID (default: 114 for MCP Subnet on mainnet)
NETUID=114

# Subtensor network: finney (mainnet), test (testnet), local
SUBTENSOR_NETWORK=finney

# Optional: Custom subtensor endpoint (overrides SUBTENSOR_NETWORK if set)
SUBTENSOR_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443


## ============================================================
## PLATFORM CONNECTION
## ============================================================

# Platform API base URL (provided by subnet operator)
PLATFORM_URL=http://platform:8000

# Platform signer SS58 address (for verifying signed responses)
# This is provided by the subnet operator
PLATFORM_SIGNER_SS58=5HpTBSw3qzgCP5QPRPYpEEAP51HTK4FYdghsG3dFuRXYqbqp


## ============================================================
## VALIDATOR SERVER SETTINGS
## ============================================================

# Validator bind address (0.0.0.0 for all interfaces)
VALIDATOR_HOST=0.0.0.0

# Validator API port
VALIDATOR_PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO


## ============================================================
## TASK POLLING CONFIGURATION
## ============================================================

# How often to poll platform for new tasks (seconds)
TASK_POLL_INTERVAL_SECONDS=15

# Maximum backoff interval when no tasks available (seconds)
MAX_BACKOFF_INTERVAL_SECONDS=300

# Backoff multiplier for exponential backoff
BACKOFF_MULTIPLIER=2.0


## ============================================================
## LLM API CONFIGURATION (OpenRouter Recommended)
## ============================================================

# LLM API endpoint (OpenRouter or OpenAI-compatible API)
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# Your API token (get from https://openrouter.ai/keys)
# Example: sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_TOKEN=

# LLM model to use for scoring
# Recommended options:
#   - openai/gpt-4o-mini (cost effective)
#   - anthropic/claude-3.5-sonnet (high quality)
#   - google/gemini-pro-1.5 (good balance)
OPENROUTER_MODEL=openai/gpt-4o-mini

# LLM request timeout (seconds)
LLM_TIMEOUT_SECONDS=240

# Maximum tokens per LLM request
LLM_MAX_TOKENS=1024

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.2


## ============================================================
## SANDBOX EXECUTION SETTINGS
## ============================================================

# Sandbox container time-to-live (seconds)
SANDBOX_DEFAULT_TTL_SECONDS=300

# Docker image for sandbox execution
SANDBOX_IMAGE=sandbox-runner:local

# Auto-build sandbox image if missing (1 = enabled, 0 = disabled)
SANDBOX_AUTO_BUILD=1


## ============================================================
## SANDBOX RUNTIME PATHS (Internal - Do Not Change)
## ============================================================
## These are used inside sandbox containers and should not be modified

INPUT_PATH=/sandbox/input/code.py
TASK_PATH=/sandbox/input/task.json
OUTPUT_PATH=/sandbox/output/output.json
